# ======================================================
# Cloudflare Tunnel 管理工具 - 环境变量配置模板
# ======================================================
# 使用方法：
#   1. 复制此文件: cp .env.example .env
#   2. 编辑 .env 填写配置
#   3. 启动服务: ./start.sh
# ======================================================

# ------------------------------------------------------
# 必填配置
# ------------------------------------------------------

# JWT 认证密钥（用于用户登录 token 签发）
# 生成命令: openssl rand -base64 32
JWT_SECRET=

# 凭证加密密钥（用于加密 Cloudflare API Token，必须 32 字节）
# 生成命令: openssl rand -base64 24
CREDENTIAL_SECRET=

# GitHub 用户名（用于从 GHCR 拉取镜像）
# 修改为你自己的 GitHub 用户名
GITHUB_USER=your-username

# ------------------------------------------------------
# 应用配置（可选，有默认值）
# ------------------------------------------------------

# 访问端口（默认 8083）
APP_PORT=8083

# 应用环境: dev / production（默认 production）
APP_ENV=production

# ------------------------------------------------------
# 数据库配置（可选，有默认值）
# ------------------------------------------------------

# 数据库驱动（默认 sqlite3）
DB_DRIVER=sqlite3

# 数据库连接字符串
# 数据存储在 ./data 目录下
DB_DSN=file:/app/data/cloudflared-tunnel.db?cache=shared&_fk=1

# ------------------------------------------------------
# JWT 配置（可选，有默认值）
# ------------------------------------------------------

# JWT 过期时间，单位：小时（默认 24）
JWT_EXPIRE_HOUR=24